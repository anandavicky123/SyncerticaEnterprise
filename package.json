{
  "name": "syncerticaenterprise",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "docker:build": "docker build -t syncertica-enterprise .",
    "docker:run": "docker-compose up -d",
    "docker:stop": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:clean": "docker system prune -f",
    "aws:init": "cd terraform && terraform init",
    "aws:plan": "cd terraform && terraform plan",
    "aws:plan:staging": "cd terraform && terraform plan -var-file=environments/staging.tfvars",
    "aws:plan:prod": "cd terraform && terraform plan -var-file=environments/production.tfvars",
    "aws:apply": "cd terraform && terraform apply",
    "aws:apply:staging": "cd terraform && terraform apply -var-file=environments/staging.tfvars",
    "aws:apply:prod": "cd terraform && terraform apply -var-file=environments/production.tfvars",
    "aws:destroy": "cd terraform && terraform destroy",
    "aws:validate": "cd terraform && terraform validate",
    "aws:fmt": "cd terraform && terraform fmt -recursive",
    "infra:validate": "npm run aws:validate && npm run aws:fmt",
    "security:audit": "npm audit --audit-level high",
    "security:fix": "npm audit fix",
    "deploy:staging": "npm run build && npm run aws:apply:staging",
    "deploy:production": "npm run build && npm run aws:apply:prod",
    "ci": "npm run lint && npm run type-check && npm run test && npm run build",
    "prepare": "husky install || true"
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch": "^3.848.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.848.0",
    "@aws-sdk/client-dynamodb": "^3.848.0",
    "@aws-sdk/client-lambda": "^3.851.0",
    "@aws-sdk/client-rds": "^3.848.0",
    "@aws-sdk/client-s3": "^3.850.0",
    "@aws-sdk/client-sns": "^3.848.0",
    "@aws-sdk/client-sqs": "^3.854.0",
    "@aws-sdk/lib-dynamodb": "^3.850.0",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^6.12.0",
    "@types/pg": "^8.15.4",
    "aws-sdk": "^2.1692.0",
    "bcryptjs": "^3.0.2",
    "chart.js": "^4.5.0",
    "dotenv": "^17.2.1",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.525.0",
    "next": "15.3.5",
    "next-auth": "^4.24.11",
    "pg": "^8.16.3",
    "prisma": "^6.12.0",
    "react": "^19.0.0",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.1.0",
    "redis": "^5.6.1",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.3.5",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
